{
  "displayName": "evenero-app frontend (Vercel)",
  "monitoredResource": {
    "type": "uptime_url",
    "labels": {
      "host": "evenero-app.vercel.app",
      "project_id": "evenero"
    }
  },
  "httpCheck": {
    "path": "/",
    "port": 443,
    "useSsl": true,
    "validateSsl": true,
    "requestMethod": "GET",
