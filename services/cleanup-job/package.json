    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "^1.5.1",
    "@google-cloud/storage": "^7.18.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/pg": "^8.11.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "5.6.3"
  }
}
