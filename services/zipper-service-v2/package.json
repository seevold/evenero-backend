{
  "name": "zipper-service-v2",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "esbuild src/index.ts src/job.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --target=node20",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/run": "^3.2.1",
    "@google-cloud/storage": "^7.18.0",
    "@google-cloud/tasks": "^6.2.2",
    "archiver": "^7.0.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "esbuild": "^0.25.10",
    "tsx": "^4.20.6",
    "typescript": "5.6.3"
  }
}
