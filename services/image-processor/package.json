{
  "name": "image-processor",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --target=node20",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.10.0",
    "@google-cloud/storage": "^7.18.0",
    "express": "^4.21.2",
    "heic-convert": "^2.1.0",
    "pg": "^8.16.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "@types/pg": "^8.11.0",
    "esbuild": "^0.25.10",
    "tsx": "^4.20.6",
    "typescript": "5.6.3"
  }
}
